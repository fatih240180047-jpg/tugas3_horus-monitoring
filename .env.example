APP_NAME="Horus SCM Intelligence"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Database MySQL (XAMPP)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=project_scm_horus-monitoring
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_TABLE=sesi

# ============================================================
# KONFIGURASI API INTELIJEN EKSTERNAL
# ============================================================
# Mode Simulasi: Atur ke false jika sudah punya API key
API_SIMULATION_MODE=false

# --- CUACA (Open-Meteo - GRATIS, tanpa API key) ---
# Tidak perlu konfigurasi apapun! Open-Meteo adalah API publik gratis.
# Dokumentasi: https://open-meteo.com/en/docs

# --- NILAI TUKAR ---
# Opsi 1: GRATIS tanpa API key (open.er-api.com) - Sudah dikonfigurasi otomatis
# Opsi 2: ExchangeRate API Premium (1500 req/bulan gratis)
# Daftar di: https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6

# --- BERITA: GNews API (Prioritas Utama - 100 req/hari GRATIS) ---
# Daftar di: https://gnews.io/ - hanya butuh email
# Setelah daftar, salin API key Anda ke sini:
GNEWS_API_KEY=

# --- BERITA: NewsAPI (Fallback - 100 req/hari GRATIS) ---
# Daftar di: https://newsapi.org/register
NEWS_API_KEY=
NEWS_API_URL=https://newsapi.org/v2

# World Bank API (Ekonomi - Publik, tidak perlu key)
WORLD_BANK_API_URL=https://api.worldbank.org/v2

# ============================================================
# KONFIGURASI LAINNYA
# ============================================================
LOG_CHANNEL=stack
LOG_LEVEL=debug
QUEUE_CONNECTION=database
CACHE_STORE=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
MAIL_MAILER=log
